def get_path_info(lval, rval):
    row = params[(params["lval"] == lval) & (params["rval"] == rval)]
    if len(row) > 0:
        estimate = row["Estimate"].values[0]
        se = row["Std. Err"].values[0] if "Std. Err" in row.columns else row["SE"].values[0]
